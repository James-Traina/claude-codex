{
  "_comment": "Routing thresholds and per-category model preferences for claude-codex.",
  "_comment_score": "classify.sh outputs a score. DELEGATE if >= delegate_threshold AND a category was matched. CLAUDE if <= claude_threshold.",

  "thresholds": {
    "delegate_threshold": 20,
    "claude_threshold": -20,
    "min_prompt_words": 3,
    "max_prompt_words_for_delegation": 200
  },

  "models": {
    "fast":    "gpt-5.3-codex-spark",
    "default": "gpt-5.3-codex",
    "capable": "gpt-5.2"
  },

  "category_models": {
    "code-generator": "default",
    "test-writer":    "default",
    "doc-writer":     "fast",
    "refactor":       "fast",
    "format":         "fast",
    "analyst":        "default"
  },

  "reasoning_effort": {
    "code-generator": "high",
    "test-writer":    "high",
    "doc-writer":     "medium",
    "refactor":       "medium",
    "format":         "low",
    "analyst":        "high"
  },

  "budget_aware": {
    "enabled": true,
    "_comment": "Budget detection: prefers CLAUDE_CONTEXT_WINDOW_USAGE_FRACTION env var (exact); falls back to transcript byte size (proxy). As usage grows, delegate_threshold is lowered so more tasks route to Codex.",
    "context_window_thresholds": {
      "_comment": "Used when CLAUDE_CONTEXT_WINDOW_USAGE_FRACTION env var is available (0.0–1.0).",
      "medium_fraction": 0.4,
      "high_fraction":   0.7
    },
    "transcript_size_thresholds": {
      "_comment": "Fallback when env var is not available.",
      "medium_bytes": 200000,
      "high_bytes":   500000
    },
    "delegate_thresholds": {
      "normal":       20,
      "medium_usage": 10,
      "high_usage":    5
    }
  },

  "sandbox": {
    "auto_delegation": "read-only",
    "manual_delegation": "workspace-write"
  },

  "delegate_signals": {
    "code_generation": {
      "weight": 30,
      "patterns": [
        "(write|create|generate) (a |an |the )?(function|method|class|interface|type|enum|struct|dto|component|hook|service|controller|handler|middleware|route|endpoint|schema|migration|model)",
        "(implement|add) (a |an |the )?(function|method|class|interface|type|route|endpoint|handler|hook)"
      ]
    },
    "test_writing": {
      "weight": 30,
      "patterns": [
        "(add|generate|write|create) (unit |integration |e2e )?tests? (for|to|covering)",
        "write (a |some )?(unit|integration|e2e|snapshot) tests?"
      ]
    },
    "documentation": {
      "weight": 30,
      "patterns": [
        "(add|generate|write) (doc(string|s)?|jsdoc|tsdoc|typedoc|apidoc|comments?) (for|to)",
        "document (this|the|all) (function|method|class|module|file|component)"
      ]
    },
    "format_lint": {
      "weight": 20,
      "patterns": [
        "(format|lint|fix style|prettify|auto.?fix|apply prettier|apply eslint)",
        "fix (formatting|indentation|whitespace|trailing|imports)"
      ]
    },
    "refactor": {
      "weight": 20,
      "patterns": [
        "(rename|extract|inline|move) (the )?(function|method|variable|const(ant)?|class|interface|type|component)",
        "refactor (this|the) (function|method|class|component|module) (to|into|for)"
      ]
    },
    "boilerplate": {
      "weight": 25,
      "patterns": [
        "(boilerplate|scaffold|skeleton|stub|placeholder|crud|getter|setter|accessor)",
        "generate (a |the )?(crud|rest|graphql|grpc) (api|endpoint|service|resource)"
      ]
    },
    "conversion": {
      "weight": 20,
      "patterns": [
        "convert (this|the) .* (to|from|into) (javascript|typescript|python|go|rust|java|kotlin|swift|c\\+\\+|c#)",
        "translate (this|the) (function|class|module|code) (to|into|from)"
      ]
    }
  },

  "claude_signals": {
    "architecture": {
      "weight": -40,
      "patterns": [
        "(architecture|architectural|design pattern|system design|design decision|design choice)",
        "(how should (i|we) structure|what.?s the best (way|approach|pattern) to (structure|organize|design))"
      ]
    },
    "security": {
      "weight": -40,
      "patterns": [
        "(securit(y|ies)|vulnerabilit|exploit|pentest|injection|csrf|xss|sqli|ssrf|rce)",
        "(auth(entication|orization|z)?|access control|permission|privilege|token (validation|verification))"
      ]
    },
    "reasoning": {
      "weight": -35,
      "patterns": [
        "\\bwhy\\b.*(doesn.?t|isn.?t|aren.?t|wasn.?t|weren.?t|can.?t|won.?t|fail|work|work)",
        "^why (is|are|does|do|did|was|were|can|would|should)"
      ]
    },
    "advisory": {
      "weight": -30,
      "patterns": [
        "(should (i|we)|would you recommend|what.?s (the best|a good) (way|approach|practice))",
        "(which (is|would be) better|pros and cons|trade.?offs?|recommend (using|against))"
      ]
    },
    "debugging": {
      "weight": -30,
      "patterns": [
        "(debug|not working|isn.?t working|broken|failing|threw (an? )?error|getting (an? )?error)",
        "(stack trace|exception|panic|segfault|crash|hang|deadlock|race condition)"
      ]
    },
    "performance": {
      "weight": -25,
      "patterns": [
        "(performance|optimize|slow(er)?|bottleneck|memory (leak|usage|issue)|cpu (usage|spike))",
        "(profile|benchmark|latency|throughput|scalab)"
      ]
    },
    "review_analysis": {
      "weight": -25,
      "patterns": [
        "(review|audit|analyze|assess|evaluate|critique) (my |this |the )?(code|implementation|approach|solution|pr|pull request)",
        "(find (issues?|bugs?|problems?|flaws?) in|what.?s wrong with)"
      ]
    },
    "explanation": {
      "weight": -20,
      "patterns": [
        "(explain|help me understand|how does|what does|tell me (about|how))",
        "(what is (the purpose|the difference|going on)|walk me through)"
      ]
    }
  }
}
